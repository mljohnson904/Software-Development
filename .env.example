# Optional environment variables for Financial Command Center

# Path to your Google service account credentials JSON file
# Default: credentials.json in the project root
GOOGLE_CREDENTIALS_FILE=credentials.json

# Email address to auto-share the spreadsheet with after creation
# Leave blank to skip sharing (you can share manually from Google Drive)
SHARE_WITH_EMAIL=

# Set to "true" to use OAuth user credentials instead of a service account
# Requires credentials_oauth.json in the project root
USE_OAUTH=false
